            font-size: 14px;
            font-weight: bold;
            text-shadow: 0 1px 0 rgba(255, 255, 255, 0.6);
            padding: .5em 1em !important;
            border-radius: 5px;
            right: 50px;
            top: 20px;
            position: absolute;
            z-index: 9;
        }

        .printlaunch:hover {
            background-color: gray;
        }

        /*STANDARDIZES TABLE FORMATTING AND COLOR*/
