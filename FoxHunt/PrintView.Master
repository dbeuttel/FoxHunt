<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="PrintView.master.cs" Inherits="FoxHunt.PrintViewMaster" %>

<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title>Print View</title>
    <script src="/js/html2canvas.min.js"></script>
    <script src="/js/jspdf.umd.min.js"></script>
    <script type="text/javascript">
        function setBarcode(item, code, text) {
            var data = { format: "code39", width: 2 }
            $.each(item.attributes, function (i, attrib) {
                data[attrib.name] = attrib.value;
            })
            if (code == null)
                code = $(item).attr("code");
            if (text == null)
                text = $(item).attr("text");
            if (text != null) data.text = text.substring(0, 20);

            if (code != null)
                $(item).JsBarcode(code, data);
        }
        $(function () {
            $("svg.barcode").each(
                function () {
                    setBarcode(this);
                }
            );
        });
    </script>

    <link href="/css/bootstrap.min.css?v=1" rel="stylesheet" />
    <link href="/css/bootstrap.min.print.css?v=2" rel="stylesheet" />
    <!-- Related styles of various icon packs and plugins -->
