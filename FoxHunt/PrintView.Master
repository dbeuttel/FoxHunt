    <style type="text/css">
        h1, h2, h3, h4, h5, h6 {
            color: black;
        }

        .page {
            width: 612px;
            height: 792px;
            border: 1px solid black;
            margin: 20px;
            position: relative;
        }

       .page .content .column {
                text-align: justify;
                font-size: 10pt;
       }

       .page .content .column blockquote {
            border-left: 2px solid #999999;
            background: #DEDEDE;
            padding: 10px;
            margin: 4px 20px;
            clear: both;
       }

        .page .content .column img {
            float: left;
            margin: 10px;
        }

