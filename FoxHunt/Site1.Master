              <script>
                  function verifyForm() {
                      var incomplete = 0;
                      $('.req').each(function () {
                          if ($(this).val() == '' || $(this).val() == 'NULL' || $(this).val() == undefined) {
                              $(this).css('background-color', 'yellow')
                              incomplete += 1;
                          }
                      })

                      if (incomplete > 0) {
                          alert('You must complete all Required Fields.')
                          return false;
                      }
                      return true;
                  }
                    jQuery.expr[':'].inscontains = function (a, i, m) {
                        return jQuery(a).text().toUpperCase()
                        .indexOf(m[3].toUpperCase()) >= 0;
                    };

                    $(function () {
                        var doSearch = function () {
                            $('tr').show();
                        $('tbody tr:not(:inscontains("' + $(".tbSearch").val() + '"),.valueCell)').hide();
                        };

                        $(".tbSearch").keyup(doSearch);

                        $(window).keydown(function (event) {
                            if (event.keyCode == 13) {
                                event.preventDefault();
                            $(".btnSearch").click();
                            return false;
                            }
                        });
                    })

                    $('body').on('click', '.btnrpt', function (event) {
                        createDlg("/reportsearch.aspx?selectedreport=" + $(this).attr("name"), "Report", 800, 1235, true);
                    event.stopPropagation();
                    })
              </script>
 
