      <script>
          function createBootstrapModal(url, title, height, width, modal, id, buttons) {
              // Create a unique ID for the modal if none is provided
              const modalId = id || 'bootstrapModal-' + Date.now();
              var sizeOverride = '';
              var sizeOverrideBOOL = false;
              if (height == '0' && width == '0') {
                  sizeOverride = 'modal-xl';
                  sizeOverrideBOOL
              }
                
              // Create the modal HTML
              let modalHtml = `
    <div class="modal ${modal ? 'fade' : ''} ${sizeOverride}" id="${modalId}" tabindex="-1" role="dialog" aria-labelledby="${modalId}Label" aria-hidden="true">
      <div class="modal-dialog" role="document" ${sizeOverrideBOOL ? 'style="max-width: ${width}px; height: ${height}px;' : ''}">
        <div class="modal-content" style='height:80%'>
          <div class="modal-header">
            <h5 class="modal-title" id="${modalId}Label">${title}</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <iframe src="${url}" style="width: 100%; ${sizeOverrideBOOL ? 'height: ${height - 100}px;' : 'height:100%;'} border: none;"></iframe>
          </div>
          <div class="modal-footer">`;

              // Add buttons
              if (buttons && Array.isArray(buttons)) {
                  buttons.forEach(button => {
                      modalHtml += `<button type="button" class="${button.class}" data-dismiss="${button.dismiss}" ${button.attributes}>${button.text}</button>`;
                  });
              } else {
                  modalHtml += `<button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Close</button>`; //Default close button
              }

              modalHtml += `
          </div>
        </div>
      </div>
    </div>
  `;

              // Append the modal to the body
              $('body').append(modalHtml);

              // Show the modal
              $('#' + modalId).modal(modal ? 'show' : { backdrop: false, show: true });

              // Optional: remove modal from DOM when closed
              $('#' + modalId).on('hidden.bs.modal', function () {
                  $(this).remove();
              });

              return modalId; // return the id of the modal.
          }

          window.createDlg = createBootstrapModal;

          window.createDialogURL = function (URL, height, width, id, title, modal) {
              return createBootstrapModal(URL, title, height, width, modal, id);
          }
      </script>

  </body>
</html>
			
