      <script type="text/javascript">
          var keepAliveInterval;
          window.onload = function () {
              keepAliveInterval = setInterval("KeepSessionAlive()", 10000);
          }

          function KeepSessionAlive() {
              var u = new URL(document.location.href);
              if (!u.pathname.toLocaleLowerCase().includes("login.aspx")) {
                  $.ajax({ url: "/keepalive.aspx" })
                      .done(function (data) {
                          if (data != "true")
                              document.location.href = "/login.aspx?ref=" + document.location.href;
                      }).fail(function () {
                          if (confirm("You have lost your connection to the site. Click ok to log back in.")) {
                              document.location.href = "/login.aspx?ref=" + document.location.href;
                          } else {
                              clearInterval(keepAliveInterval);
                              keepAliveInterval = setInterval("KeepSessionAlive()", 180000);
                          }
                      });
              }
          }

