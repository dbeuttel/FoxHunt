          function getCycleList() {
              if ($(".otherCyc").length)
                  $(".otherCyc").slideUp(function () { $(".otherCyc").remove(); });
              else {
                  $.get("/default.aspx?CycleList=Y", function (d) {
                      var x = $.parseJSON(d);
                      var container = $("<div>")
                          .attr("class", "otherCyc")
                          .hide();
                      $(".cycles").append(container);
                      for (var i = 0; i < x.rows.length; i++) {
                          var r = x.rows[i];
                          var itm = $("<a>")
                              .text(r.cyclename)
                              .attr("href", "/default.aspx?CycleId=" + r.id)
                              .attr("class", "btn cycoption btn-secondary col");
                          if ($(".CurrentCycle").text().trim() == r.cyclename.trim())
                              itm.addClass("btn-success")
                          container.append(itm);
                      }
                      container.slideDown()
                  });
              }
          }

          function selectCode(code) {
              var urlParams = new URLSearchParams(window.location.search);
              console.log("select barcode:" + code);
              if (code.length > 0) {

                  //var clickbtn = urlParams.get('clickbutton');
                  //if ($('.pnlAudit').is(':visible'))
                  //    clickbtn = 'btnaudit';
                  //if ($('.pnladdsub').is(':visible'))
                  //    clickbtn = 'btnmod';
                  ////alert(clickbtn);

                  //if (code[0] == "I")
                  //    window.location.href = "/addsubinv.aspx?barcode=" + code + "&clickbutton=" + clickbtn;
                  //else
                  window.location.href = "/Inventory/InventoryManager.aspx?barcode=" + code
              }
          }

          $(function () {
              //Election Cycle Picker, next 6 lines
              $(".CurrentCycle").click(getCycleList);

              $('.elecSelOpt').each(function () {
                  if ($(this).attr('elecSelOpt') == $(this).attr('selectedElection'))
                      $(this).parent().addClass('selectedSubElection')
              })

              //Add active to the proper nav-link li
              //$('.nav-link').each(function () {
              //    if (window.location.href.toLowerCase().indexOf($(this).attr('href').toLowerCase()) !== -1) {
              //        $(this).addClass('active');
              //    }
              //});
              var currentUrl = window.location.pathname + window.location.search;

              $('.nav-link').each(function () {
                  var link = $(this).attr('href');

                  if (link) { // ✅ Only proceed if href is not null/undefined
                      // Remove hash from link for comparison
                      var linkNoHash = link.split('#')[0].toLowerCase();

                      if (currentUrl.toLowerCase().startsWith(linkNoHash) && link != '#') {
                          $(this).addClass('active');
                      }
                  }
              });
              $('.menu-link').each(function () {
                  var link = $(this).attr('href');

                  if (link) { // ✅ Only proceed if href is not null/undefined
                      // Remove hash from link for comparison
                      var linkNoHash = link.split('#')[0].toLowerCase();
                      linkNoHash = linkNoHash.split('dashboard')[0].toLowerCase();

                      if (currentUrl.toLowerCase().startsWith(linkNoHash)) {
                          $(this).addClass('active');
                          $(this).parent().addClass('active open');
                      }
                  }
              });


          });

          function editDropDownList(ddName) {
              createDialogURL('/EditDDl.aspx?ddName=' + ddName, 0, 0, null, 'Edit Dropdown List', true);
              //window.location.href = '/EditDDl.aspx?ddName=' + ddName;
          }

          function reportBug(id) {
              createDialogURL("/Admin/ReportBug.aspx?d=y&id=" + id, 500, 400, null, "Report Bug", true);
          }

          function showProfile(profileID) {
              createDialogURL("/Profile.aspx?d=y&id=" + profileID, 0, 0, null, "Profile", true);
          }

          $('button').attr('type', 'button');

          //function showEvent(eventID) {
          //    createDialogURL("/Events/EventEdit.aspx?d=y&id=" + eventID, 600, 900, null, "Event", true);
          //}
      </script>
      

      
